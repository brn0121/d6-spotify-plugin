# Dependencies
plugin/node_modules/

# Compiled bundle — generated by: npm run build
plugin/build/

# OAuth tokens — encrypted but machine-specific; never commit credentials
plugin/tokens.enc

# Client ID — enter via the Property Inspector, not source control
plugin/config.json

# Runtime logs
plugin/log/
log/

# Release output (generated by scripts/release.sh)
dist/

# Dev helper (local only)
plugin/autofile.js

# Editor / tool config
.claude/
.idea/
.vscode/
*.DS_Store
